{
  "name": "aethermind-ai",
  "displayName": "AetherMind AI",
  "description": "Built-in AI inline completion powered by Anthropic Claude",
  "version": "1.0.0",
  "publisher": "AetherMind",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "AetherMind AI",
      "properties": {
        "aethermind.apiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key for AI completion",
          "order": 1
        },
        "aethermind.model": {
          "type": "string",
          "default": "claude-3-5-sonnet-20241022",
          "description": "AI model to use for completions",
          "enum": [
            "claude-3-5-sonnet-20241022",
            "claude-3-5-haiku-20241022",
            "claude-3-opus-20240229",
            "claude-3-sonnet-20240229",
            "claude-3-haiku-20240307"
          ],
          "order": 2
        },
        "aethermind.apiEndpoint": {
          "type": "string",
          "default": "https://api.anthropic.com/v1/messages",
          "description": "API endpoint for Anthropic",
          "order": 3
        },
        "aethermind.maxTokens": {
          "type": "number",
          "default": 256,
          "minimum": 1,
          "maximum": 4096,
          "description": "Maximum tokens for completion",
          "order": 4
        },
        "aethermind.enableInlineCompletion": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline AI completion",
          "order": 5
        },
        "aethermind.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 1,
          "description": "Temperature for AI model (0-1)",
          "order": 6
        },
        "aethermind.timeout": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "maximum": 120000,
          "description": "Request timeout in milliseconds",
          "order": 7
        }
      }
    },
    "commands": [
      {
        "command": "aethermind.toggleCompletion",
        "title": "Toggle AI Inline Completion",
        "category": "AetherMind AI"
      },
      {
        "command": "aethermind.setApiKey",
        "title": "Set API Key",
        "category": "AetherMind AI"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0"
  }
}
